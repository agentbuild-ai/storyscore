# ─── AI Provider ─────────────────────────────────────────────────────────────
# Set to 'ollama' for local development (free, no API costs)
# Set to 'claude' for testing and production (requires Anthropic API key)
AI_PROVIDER=ollama

# ─── Ollama (development) ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── Anthropic / Claude (testing + production) ────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_CHAT_MODEL=claude-haiku-4-5-20251001
CHAT_TURN_LIMIT=8
SCORE_RATE_LIMIT=20

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_secret_key_here

# ─── Langfuse (LLM observability + evaluation) ────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Client (Vite — must be prefixed VITE_ to expose to browser) ──────────────
VITE_API_BASE_URL=http://localhost:3001
VITE_ACCESS_CODE=your_access_code_here
